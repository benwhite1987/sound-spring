#!/usr/bin/env bash
set -euo pipefail

SOUNDBOARD_LIB="${XDG_DATA_HOME:-$HOME/.local/share}/soundspring"

if [[ -f "$SOUNDBOARD_LIB/audio-common.sh" ]]; then
    # shellcheck source=audio-common.sh
    source "$SOUNDBOARD_LIB/audio-common.sh"
    stop_sound_spring_playback
elif [[ -f "$SOUNDBOARD_LIB/pipewire-common.sh" ]]; then
    # shellcheck source=pipewire-common.sh
    source "$SOUNDBOARD_LIB/pipewire-common.sh"
    stop_sound_spring_playback
else
    pkill -f 'soundspring/play-file.sh' 2>/dev/null || true
    pkill -f 'paplay --device=soundboard_sfx' 2>/dev/null || true
fi
