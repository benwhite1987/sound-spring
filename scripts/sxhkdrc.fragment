# Sound Spring hotkey bindings (include from ~/.config/sxhkd/sxhkdrc)
# Play slots 1-9 and 0 (which maps to slot 10)
super + {1,2,3,4,5,6,7,8,9,0}
    sb-play {1,2,3,4,5,6,7,8,9,0}

# Cycle tabs
super + bracketright
    sb-tab next
super + bracketleft
    sb-tab prev

# Panic
super + Escape
    sb-stop
