#!/usr/bin/env bash
set -euo pipefail

SLOT="${1:-}"
SINK="soundboard_sfx"
SOUNDBOARD_LIB="${XDG_DATA_HOME:-$HOME/.local/share}/soundspring"

# shellcheck source=pipewire-common.sh
source "$SOUNDBOARD_LIB/pipewire-common.sh"
# shellcheck source=config-common.sh
source "$SOUNDBOARD_LIB/config-common.sh"
# shellcheck source=state-common.sh
source "$SOUNDBOARD_LIB/state-common.sh"

if [[ ! "$SLOT" =~ ^[0-9]$ ]]; then
    echo "usage: sb-play <slot 0-9>" >&2
    exit 1
fi

if ! sink_exists "$SINK"; then
    mic_source=""
    latency_ms="$(read_audio_latency_ms)"
    if mic_source="$(read_audio_mic_source 2>/dev/null)"; then
        :
    else
        mic_source=""
    fi
    if ! setup_soundboard_pipewire "$mic_source" "$latency_ms"; then
        notify-send "Sound Spring" "PipeWire setup failed"
        exit 1
    fi
fi

TAB_DIR="$(ensure_current_tab_path)" || { notify-send "Sound Spring" "No tabs"; exit 1; }

if [[ ! -d "$TAB_DIR" ]]; then
    notify-send "Sound Spring" "Tab not found: $(basename "$TAB_DIR")"
    exit 1
fi

# slot 0 → slot 10, slots 1-9 → slots 1-9
if [[ "$SLOT" == "0" ]]; then
    TARGET_SLOT=10
else
    TARGET_SLOT=$SLOT
fi

FILE="$(resolve_tab_slot_file "$TAB_DIR" "$TARGET_SLOT" || true)"
if [[ -z "$FILE" ]]; then
    notify-send "Sound Spring" "Empty slot $SLOT"
    exit 0
fi

if ! play_audio_file_async "$SINK" "$FILE"; then
    notify-send "Sound Spring" "Cannot play: $(basename "$FILE")"
    exit 1
fi
