#!/usr/bin/env bash
set -euo pipefail

SOUNDBOARD_LIB="${XDG_DATA_HOME:-$HOME/.local/share}/soundspring"

# shellcheck source=state-common.sh
source "$SOUNDBOARD_LIB/state-common.sh"
# shellcheck source=tabs-common.sh
source "$SOUNDBOARD_LIB/tabs-common.sh"

mapfile -t TABS < <(list_tab_paths)
COUNT=${#TABS[@]}
[[ $COUNT -eq 0 ]] && { notify-send "Sound Spring" "No tabs"; exit 1; }

CURRENT="$(ensure_current_tab_path)"
CUR_IDX=0
for i in "${!TABS[@]}"; do
    [[ "${TABS[$i]}" == "$CURRENT" ]] && CUR_IDX=$i
done

case "${1:-}" in
    next) NEW=$(( (CUR_IDX + 1) % COUNT )) ;;
    prev) NEW=$(( (CUR_IDX - 1 + COUNT) % COUNT )) ;;
    *)
        echo "usage: sb-tab next|prev" >&2
        exit 1
        ;;
esac

write_current_tab "${TABS[$NEW]}"
notify-send -t 1500 "Sound Spring" "Tab: $(tab_display_name "${TABS[$NEW]}")"
